# Medusa Backend Environment Variables Template
# Copy this file to a new file named '.env' and adjust the values for your local environment.

# Database settings (Replace with your local Postgres credentials and database name)
DATABASE_URL=postgres://postgres:your_local_postgres_password@localhost/your_local_medusa_database_name

# CORS Configuration (Allows frontend connections)
STORE_CORS=http://localhost:8000,http://localhost:3000,https://docs.medusajs.com
ADMIN_CORS=http://localhost:5173,http://localhost:9000,https://docs.medusajs.com
AUTH_CORS=http://localhost:5173,http://localhost:9000,http://localhost:8000,https://docs.medusajs.com

# Redis Connection URL (Optional if using local Redis for caching/events)
# REDIS_URL=redis://localhost:6379

# Secrets (Change these to unique random strings in your local .env)
JWT_SECRET=your_local_jwt_secret_here
COOKIE_SECRET=your_local_cookie_secret_here
AUTH_MFA_ENCRYPTION_KEY=091e6f96eb787b2d8fd3e52b4c1668585cd9442085e31a4f7c38aae59cde107b

# Next.js integration details
MEDUSA_ADMIN_ONBOARDING_TYPE=nextjs
MEDUSA_ADMIN_ONBOARDING_NEXTJS_DIRECTORY=my-electronics-store\apps\storefront
